# Copy this file to ".env" and fill in your values.
# .env is gitignored — never commit it. Use GitHub Actions secrets for the hosted version.
# Only SEC_USER_AGENT is required to run the core app. Everything else is optional.

# ─────────────────────────────────────────────
# REQUIRED — SEC EDGAR fair-access User-Agent
# ─────────────────────────────────────────────
# SEC rules require a descriptive string with a real email you control.
# Without this (or with the placeholder), EDGAR returns HTTP 403 on every request.
# Format: "AppName YourName your@email.com"
SEC_USER_AGENT=StockAlertApp YourName you@email.com

# ─────────────────────────────────────────────
# OPTIONAL — Financial Modeling Prep API key
# ─────────────────────────────────────────────
# Free tier: 250 calls/day. No credit card required.
# Get it at: https://financialmodelingprep.com/developer/docs → "Get API Key"
# Enables:
#   - Peer-list for comps valuation (the "comps_percentile" factor in cheapness scoring)
#   - Politicians tab (FMP senate-latest / house-latest endpoints)
#   - Excel deep-dive reports (Comps tab peer data)
# Without this key: valuation falls back to value_score + DCF only (still works),
# and the Politicians tab shows "no FMP_API_KEY" message.
FMP_API_KEY=

# ─────────────────────────────────────────────
# OPTIONAL — Telegram push alerts
# ─────────────────────────────────────────────
# Sends the top 5 alerts to your phone when you run: python run.py --notify
# Step 1: Create a bot — message @BotFather on Telegram → /newbot → copy the token.
# Step 2: Get your chat ID — message your new bot once, then visit:
#   https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#   Look for "chat":{"id": <NUMBER>} — that number is your TELEGRAM_CHAT_ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────
# OPTIONAL — GitHub Personal Access Token
# ─────────────────────────────────────────────
# Only needed if you use deploy_github.py (the one-shot automated deployer).
# For manual GitHub setup (following DEPLOY.md), you don't need this.
# Create at: https://github.com/settings/tokens → "Generate new token (classic)"
# Required scopes: repo, workflow, admin:public_key
GH_TOKEN=

# ─────────────────────────────────────────────
# OPTIONAL — Signal tuning knobs
# ─────────────────────────────────────────────
# Safe to leave at defaults. Only change if you want to tune signal sensitivity.

# How many recent Form 4 filings to scan each run (higher = more coverage, slower)
INSIDER_FEED_COUNT=80

# Window to group insider buys into a "cluster" (days)
CLUSTER_LOOKBACK_DAYS=7

# Minimum number of distinct insiders buying the same stock to trigger an alert
MIN_CLUSTER_INSIDERS=2

# Minimum federal contract award size to track (in USD — default $10M)
MIN_CONTRACT_USD=10000000

# How far back to look for new contract awards (days)
CONTRACT_LOOKBACK_DAYS=5
