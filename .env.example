# Copy to ".env" and fill in. Only SEC_USER_AGENT is required.

# REQUIRED by SEC fair-access rules — use a REAL email you control, or EDGAR returns HTTP 403.
SEC_USER_AGENT=StockAlertApp personal-use you@example.com

# OPTIONAL — turns on the "undervalued" gate (the "Both" mode). Free FMP key, 250 calls/day.
FMP_API_KEY=

# OPTIONAL — phone push. Create a bot via @BotFather, then message it and read your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OPTIONAL tuning
INSIDER_FEED_COUNT=80
CLUSTER_LOOKBACK_DAYS=7
MIN_CLUSTER_INSIDERS=2
MIN_CONTRACT_USD=10000000
CONTRACT_LOOKBACK_DAYS=5
